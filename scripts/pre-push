#!/bin/sh

# Pre-push hook to run pytest before pushing code to remote repo.
# If tests fail, the push is prevented.

echo "========================================="
echo "Running pytest suite before pushing..."
echo "========================================="

# Run the pytest suite
uv run pytest

RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo ""
  echo "❌ Error: Pytest suite failed! Push aborted."
  echo "Please fix the failing tests before pushing."
  echo "========================================="
  exit 1
fi

echo ""
echo "========================================="
echo "Running LLM verification before pushing..."
echo "========================================="

# Run LLM verification
uv run python scripts/verify_llms.py

LLM_RESULT=$?

if [ $LLM_RESULT -ne 0 ]; then
  echo ""
  echo "❌ Error: LLM verification failed! Push aborted."
  echo "========================================="
  exit 1
fi

echo ""
echo "========================================="
echo "Running Ruff lint checks before pushing..."
echo "========================================="

# Run Ruff lint
uv run ruff check .

RUFF_RESULT=$?

if [ $RUFF_RESULT -ne 0 ]; then
  echo ""
  echo "❌ Error: Ruff lint checks failed! Push aborted."
  echo "========================================="
  exit 1
fi

echo ""
echo "========================================="
echo "Running Mypy type checks before pushing..."
echo "========================================="

# Run Mypy type-checking
uv run mypy .

MYPY_RESULT=$?

if [ $MYPY_RESULT -ne 0 ]; then
  echo ""
  echo "❌ Error: Mypy type checks failed! Push aborted."
  echo "========================================="
  exit 1
fi

echo ""
echo "✅ Success: All tests, lints, type checks, and LLM verifications passed. Proceeding with push."
echo "========================================="
exit 0
