# Example environment file — list of environment variables used by the project
# Copy this file to `.env` and fill in real secrets. Do NOT commit `.env`.
# Use forward slashes on Windows to avoid escaping backslashes in some tools.
PROJECT_ROOT=D:/Github-Projects/Autonomous-Multi-Agent

# OpenAI API Configuration
OPENAI_API_KEY=

# Groq API Configuration
GROQ_API_KEY=

# Google Gemini API Configuration
GEMINI_API_KEY=

# Anthropic API Configuration
ANTHROPIC_API_KEY=

# Ollama Configuration (optional - defaults to http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

